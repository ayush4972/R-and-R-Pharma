# Port the Express server listens on
# (5001 by default — macOS Control Center/AirPlay occupies 5000)
PORT=5001

# CORS: the origin of your deployed frontend (use * for local dev)
CLIENT_ORIGIN=http://localhost:5173

# Resend API key — get one at https://resend.com (Dashboard → API Keys)
RESEND_API_KEY=your_resend_api_key_here

# Where contact form submissions are delivered
EMAIL_TO=gyanshankerdeo@gmail.com

# Sender address. Resend requires this to be on a domain you've verified.
# Leave unset to use Resend's shared testing sender (onboarding@resend.dev).
# Once your domain is verified, set e.g.:
# EMAIL_FROM=R & R Pharma Website <noreply@yourdomain.com>
EMAIL_FROM=R & R Pharma Website <onboarding@resend.dev>
